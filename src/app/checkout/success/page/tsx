import Stripe from "stripe";

type SearchParams = Promise<{
  session_id?: string;
}>;

type PageProps = {
  searchParams: SearchParams;
};

function getStripe() {
  if (!process.env.STRIPE_SECRET_KEY) {
    throw new Error("STRIPE_SECRET_KEY is required");
  }

  return new Stripe(process.env.STRIPE_SECRET_KEY);
}

function formatMoney(amount: number | null | undefined, currency: string | null | undefined) {
  if (typeof amount !== "number") return "";
  return new Intl.NumberFormat("en-GB", {
    style: "currency",
    currency: (currency || "GBP").toUpperCase(),
  }).format(amount / 100);
}

export default async function CheckoutSuccessPage({ searchParams }: PageProps) {
  const { session_id } = await searchParams;

  if (!session_id) {
    return (
      <main style={{ maxWidth: 800, margin: "40px auto", padding: 16 }}>
        <h1>Payment confirmation unavailable</h1>
        <p>Missing Stripe session ID.</p>
      </main>
    );
  }

  try {
    const stripe = getStripe();

    const session = await stripe.checkout.sessions.retrieve(session_id, {
      expand: ["payment_intent"],
    });

    return (
      <main style={{ maxWidth: 800, margin: "40px auto", padding: 16 }}>
        <div
          style={{
            border: "1px solid #ddd",
            borderRadius: 12,
            padding: 24,
            background: "#fff",
          }}
        >
          <h1 style={{ marginTop: 0 }}>Payment successful</h1>

          <p>Thank you. Your payment has been received.</p>

          <hr style={{ margin: "20px 0" }} />

          <p>
            <strong>Amount paid:</strong>{" "}
            {formatMoney(session.amount_total, session.currency)}
          </p>

          <p>
            <strong>Payment status:</strong> {session.payment_status}
          </p>

          <p>
            <strong>Name:</strong> {session.customer_details?.name || "—"}
          </p>

          <p>
            <strong>Email:</strong> {session.customer_details?.email || "—"}
          </p>

          <p>
            <strong>Reservation token:</strong>{" "}
            {session.metadata?.reservation_token || "—"}
          </p>

          <p>
            <strong>Checkout session:</strong> {session.id}
          </p>

          <p>
            <strong>Payment intent:</strong>{" "}
            {typeof session.payment_intent === "string"
              ? session.payment_intent
              : session.payment_intent?.id || "—"}
          </p>

          <hr style={{ margin: "20px 0" }} />

          <p style={{ marginBottom: 0 }}>
            Your tickets have been marked as sold once the Stripe webhook completes.
          </p>
        </div>
      </main>
    );
  } catch (error) {
    console.error("checkout success page error", error);

    return (
      <main style={{ maxWidth: 800, margin: "40px auto", padding: 16 }}>
        <h1>Payment received</h1>
        <p>
          Your payment appears to have completed, but the confirmation details
          could not be loaded.
        </p>
      </main>
    );
  }
}
